ladder <- function(data, x)
{
## match call arguments
.args <- as.list(match.call())
x <- as.character(.args$x)
.x <- data[[.args$x]]
## get ladder vectors
.t <- list(.x^3,
.x^2,
.x,
sqrt(.x),
log(.x),
1 / sqrt(.x),
1 / .x,
1 / .x^2,
1 / .x^3)
## get chi W and p-value
.s <- do.call(
rbind,
lapply(.t, function(z) {
.s <- shapiro.test(z)
sprintf(c(.s$statistic, .s$p.value),
fmt = paste0("%#.", 5, "f"))
})
)
## combine all
.df <- data.frame(c("cube", "squre", "raw", "square-root", "log",
"reciprocal root", "reciprocal", "reciprocal square",
"reciprocal cube"),
c(paste0(x, c("^3", "^2", "")),
paste0("sqrt(", x, ")"),
paste0("log(", x, ")"),
paste0("1 / sqrt(", x, ")"),
paste0("1 / ", x),
paste0("1 / (", x, "^2)"),
paste0("1 / (", x, "^3)")),
.s)
names(.df) <- c("Transformation", "formula", "W", "P-Value")
.df <- addDashLines(.df, .vline = 2)
## print df
print(.df, "Ladder of Transformation")
invisible(.df)
}
ladder(elemapi, enroll)
ladder <- function(data, x)
{
## match call arguments
.args <- as.list(match.call())
x <- as.character(.args$x)
.x <- data[[.args$x]]
## get ladder vectors
.t <- list(.x^3,
.x^2,
.x,
