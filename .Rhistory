library(mStats)
## clear R workspace
rm(list = ls())
## load packages
library(magrittr)
library(mStats)
## read dataset
patient <- haven::read_dta("https://stats.idre.ucla.edu/stat/data/patient_pt1_stata_dm.dta")
## problems in patient data
## data management
patient2 <- patient %>%
## replace age with NA if age > 100
replace(age, NA, age>100) %>%
## replace lungcapacity with NA if lungcapacity == -99 or -98
replace(lungcapacity, NA, lungcapacity == -99 | lungcapacity == -98) %>%
replace(test1, NA, test1 == -99) %>%
replace(test2, NA, test2 == -99) %>%
## replace wbc with numerical version
replace(wbc, as.numeric(wbc)) %>%
## replace familyhx and smokinghx with NA if they are -99
replace(familyhx, NA, familyhx == -99) %>%
replace(smokinghx, NA, smokinghx == -99) %>%
replace(sex, NA, sex == 12.2) %>%
## binary variable: generate
generate(gender, as.numeric(sex == "male"))
