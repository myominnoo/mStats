.df <- merge.data.frame(.data, .dx,
by = .vars, all.x = TRUE)
## re fit model with hat_ and hatsq_
.txt <- paste0("lm(", .vars[1], " ~ hat_ + hatsq_, data = .df)")
.refit <- eval(parse(text = .txt))
.list <- regress(.refit, vce = vce, rnd = rnd)
invisible(.list)
}
linkTest(fit)
names(elemapi)
