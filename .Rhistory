.x[[.ni[z]]], " (", .x[[.pi[z]]], ")"
))
names(.df) <- paste0(names(.x)[.ni[z]], " (%)")
.df
})
)
## remove n % columns
.x <- .x[, c(1:2, .nc - 1, .nc)]
## Move variable names one row up.
.x$Variables[.ndash] <- .x$Variables[.ndash + 1]
## combine all and process dashlines
.df <- cbind(.x[, 1:2], .df, .x[, 3:4])
.df[.ndash, 2:ncol(.df)] <- .df[.ndash[-length(.ndash)] + 1, 1] <- ""
.nr <- nrow(.df)
