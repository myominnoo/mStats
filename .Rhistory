library(mStats)
library(survival)
data(lung)
## incidence rates
strate(lung, time, status, per = 100000)
## stratified incidence rates
strate(lung, time, status, sex, fail = 1, per = 100000)
strate(lung, time, status, sex, fail = 2, per = 100000)
