svytab(os, bakedham:fruitsalad)
svytab(os, bakedham:fruitsalad, value = TRUE)
svytab(os, bakedham:fruitsalad, value = NA)
svytab(infert, case, induced, spontaneous)
svytab(infert, case, induced, spontaneous, value = 1)
