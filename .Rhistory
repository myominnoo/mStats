## Simpson's paradox
## Burt Gerstman's Epidemiology, page 326, table 14.1
simpson <- expandTables("1" = c(1000, 9000, 50, 950),
"2" = c(95, 5, 5000, 5000),
exp_name = "trt",
exp_lvl = c("new", "standard"),
case_name = "case",
case_lvl = c("alive", "dead"),
strata_name = "clinic")
## calculate RR
mhrr(simpson, trt, case, exp_value = "new", case_value = "alive")
## calculate MH RR
mhrr(simpson, trt, case, clinic)
mhor(simpson, trt, case, exp_value = "new", case_value = "alive")
## calculate MH RR
mhor(simpson, trt, case, clinic)
## calculate RR
mhrr(simpson, trt, case, exp_value = "new", case_value = "alive")
## calculate MH RR
mhrr(simpson, trt, case, clinic)
mhor(simpson, trt, case, exp_value = "new", case_value = "alive")
## calculate MH RR
mhor(simpson, trt, case, clinic)
## calculate RR
mhrr(simpson, trt, case, exp_value = "new", case_value = "alive")
## calculate MH RR
