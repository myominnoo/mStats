trial <- expandTables(c(20, 220, 80, 140),
exp_name = "vaccine",
exp_lvl = c("vacc", "placebo"),
case_name = "influenza",
case_lvl = c("yes", "no"))
trial <- labelData(trial, "an influenza vaccine trial")
trial <- labelVar(trial, vaccine="Vaccine or placebo", influenza="Yes or no")
mhrr(trial, vaccine, influenza)
mhrr(simpson, trt, case, clinic)
mhrr(simpson, trt, case)
lung <- expandTables(
c(39, 29961, 6, 59994),
exp_name = "smoking",
exp_lvl = c("Smokers", "Non-smokers"),
case_name = "cancer",
case_lvl = c("Yes", "No")
)
## label variable and dataset
lung <- labelVar(lung, smoking="Yes or No", cancer="Yes or no")
lung <- labelData(lung, "Follow up lung cancer study")
## check dataset
codebook(lung)
## calculate RR
mhrr(lung, smoking, by = cancer, exp_value = "Smokers", case_value = "Yes")
mhrr(lung, smoking, cancer, exp_value = "Smokers", case_value = "Yes")
mhrr(simpson, trt, case)
simpson <- expandTables("1" = c(1000, 9000, 50, 950),
"2" = c(95, 5, 5000, 5000),
exp_name = "trt",
exp_lvl = c("new", "standard"),
case_name = "case",
case_lvl = c("alive", "dead"),
strata_name = "clinic")
## calculate RR
mhrr(simpson, trt, case)
mhrr(simpson, trt, case, exp_value = "new", case_value = "alive")
mhrr(simpson, trt, case, clinic)
rm(list = ls())
