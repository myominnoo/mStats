linkTest <- function(regress, vce = FALSE, rnd = 5)
{
## get the model from list object
.model <- regress$model
## get the original data
.data <- regress$data
## get vars name in the model
.vars <- all.vars(formula(.model))
## predict hat values
.fit <- predict(.model)
.fit2 <- .fit^2
}
regress(fit) %>%
linkTest()
linkTest <- function(regress, vce = FALSE, rnd = 5)
{
## get the model from list object
.model <- regress$model
## get the original data
.data <- regress$data
## get vars name in the model
.vars <- all.vars(formula(.model))
## predict hat values
.fit <- predict(.model)
.fit2 <- .fit^2
# Check to see that the predicted and predicted^2 variable actually
# vary.
if(round(var(.fit), digits=2) == 0){
stop("No parameters that vary. Cannot perform test.")
}
.df <- cbind(.model$model,
hat_ = .fit,
hatsq_ = .fit2)
.df
}
regress(fit) %>%
linkTest()
