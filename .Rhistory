source("./R/mStats.R")
os <- epicalc::Oswego
codebook(os)
os <- os %>%
label(bakedham = "Baked Ham",
jello = "Jelly fruit")
epicalc::tableStack(bakedham:fruitsalad, dataFrame=os)
svytab <- function(data, ... , value = NULL)
{
