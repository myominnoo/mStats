library(mStats)
panel <- haven::read_dta("https://dss.princeton.edu/training/Panel101.dta")
logit(panel, y_bin, x1, x2, x3, x4, x5, x6, x7)
codebook(panel)
logit(panel, y_bin, x1, x2, x3)
m1 <- logit(panel, y_bin, x1)
m2 <- logit(panel, y_bin, x1, x2)
m3 <- logit(panel, y_bin, x1, x2, x3)
esttab(m1, m2, m3)
esttab(m3)
m4 <- logit(panel, y_bin, x1, x2, x3, opinion)
esttab(m3, m4)
codebook(panel)
tab(panel, opinion)
panel <- replace(panel, opinion, factor(opinion))
m4 <- logit(panel, y_bin, x1, x2, x3, opinion)
m4 <- logit(panel, y_bin, x1, x2, x3, opinion, or = FALSE)
panel <- haven::read_dta("https://dss.princeton.edu/training/Panel101.dta")
codebook(panel)
tab(panel, opinion)
panel <- recode(panel, opinion,
1-"1strAg",
2-"2Ag",
3-"3Dis",
4-"4StrDis")
m1 <- logit(panel, y_bin, x1)
m2 <- logit(panel, y_bin, x1, x2)
m3 <- logit(panel, y_bin, x1, x2, x3)
m4 <- logit(panel, y_bin, x1, x2, x3, opinion, or = FALSE)
esttab(m3, m4)
library(mfx)
install.packages("mfx") #Do this only once
library(mfx)
logitmfx(y_bin ~ x1+x2+x3+opinion, data=panel)
logitmfx
logitmfx(y_bin ~ x1+x2+x3+opinion, data=panel)
mf <- logitmfx(y_bin ~ x1+x2+x3+opinion, data=panel)
mf
str(mf)
summary(mf)
