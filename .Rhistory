#`````````````  Data Analysis for Political Determinants ````````````
#````````````````````````````````````````````````````````````````````
#````````````````````````````````````````````````````````````````````
# Author: Myo Minn Oo
# Date of creation: 29th August 2020
# Date of last updated: 29th August 2020
# Objectives: to explore ecological association between five political
# indicators and three health indicators controlling for GDP.
## political indicators
## 1) corruption perception index
## 2) democracy index
## 3) human rights index
## 4) human freedom index
## 5) press freedom index
## health indicators 1) life expectancy, 2) MMR and 3) IMR
# SET UP R ENVIRONMENT ----------------------------------------------------
clear()
## load necessary packages
# install.packages("dplyr")
# install.packages("magrittr")
# install.packages("readxl")
# install.packages("https://myominnoo.github.io/pages/r/mStats_3.3.1.tar.gz", repos = NULL, type = "source")
library(dplyr)
library(magrittr)
library(mStats)
## data import from excel to R
# pdh <- readxl::read_excel("./data/pdh.xlsx")
path <- "C:/MEGA/Work/Projects/political_determinants/da"
pdh <- readxl::read_excel(paste0(path, "./data/pdh.xlsx"))
# DATA MANAGEMENT ---------------------------------------------------------
df <- pdh %>%
rename(who = whoregion, le = lifeexp, u5 = under5,
hri = hr, pfi = pf, hfi = hf, di = demo) %>%
labelVar(who = "WHO Region",
country = "Country name",
le = "Life expectancy",
mmr = "Maternal mortality rate",
u5 = "Under 5 child mortality rate",
hri = "Human rights index",
cpi = "Corruption perception index",
pfi = "Press freedom index",
hfi = "Human freedom index",
di = "Democracy index",
gdp = "GDP per capita") %>%
labelData("Political determinants versus health indicators")
## Data exploration
codebook(df)
summ(df)
tab(df, who)
summ(df, by = who)
## Scatter plot matrix
df %>%
select(-who, -country) %>%
scatterPlotMatrix()
# LINEAR REGRESSION -------------------------------------------------------
## Fit the model
fit <- lm(le ~ hri + cpi + pfi + hfi + di + gdp, data = df)
## Generate regression report
regress(fit)
library(dplyr)
library(magrittr)
library(mStats)
clear()
regress(fit)
library(mStats)
fit <- lm(induced ~ education + parity + case, data = infert)
regress(fit)
library(dplyr)
library(magrittr)
library(mStats)
clear()
fit <- lm(induced ~ education + parity + case, data = infert)
regress(fit)
