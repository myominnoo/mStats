.df <- data.frame(.df)
names(.df) <- c("Null Hypothesis", "Variables",
"Chi2(1)", "Prob > Chi2")
.df <- formatdf(.df, 2, 2)
## Display information
printDFlenLines(.df)
cat(paste0("       Breusch-Pagan test for heteroskedasticity\n"))
printDFlenLines(.df)
print.data.frame(.df, row.names = FALSE, max = 1e9)
invisible(.df)
}
