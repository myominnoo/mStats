## match call arguments
args <- as.list(match.call())
## get variable names
model_names <- enquotes(args, c("get", "digits"))
co <- capture.output(fits <- lapply(models, regress, digits = digits))
## get individual summary output
fit <- lapply(fits, function(z) {
reg <- z$reg
reg <- reg[3:(nrow(reg) - 1), c(2, 4, 5, 7, 8, 9)]
names(reg) <- c("var", "coef", "se", "pvalue", "ll", "ul")
p <- as.numeric(reg$pvalue)
p <- ifelse(p < 0.05, "*",
ifelse(p < 0.01, "**",
ifelse(p < 0.001, "***", "")))
## combine
se <- data.frame(var = reg$var,
coef = paste0(reg$coef, " (", reg$se, ")", p))
ci <- data.frame(var = reg$var,
coef = paste0(reg$coef, " (", reg$ll, " - ", reg$ul, ")", p))
## get info
info <- z$info[3:7, c(2, 4)]
info[2, 1] <- "F value"
names(info) <- names(se)
switch(get[1],
se = rbind(se, info),
ci = rbind(ci, info))
})
df <- Reduce(function(x, y) merge(x, y, by = "var", all = TRUE, sort = FALSE),
fit)
ic <- grepl("(Intercept)", df$var)
st <- df$var %in% c("Number of Obs", "F value", "Prob > F",
"R-Squared", "Adj R-Squared")
df_raw <- rbind(df[0, ], df[!(ic | st), ], df[ic | st, ])
names(df_raw) <- c("Predictors", model_names)
df_raw[is.na(df_raw)] <- ""
row.names(df_raw) <- NULL
## formatting for output
df <- formatdf(df_raw, 2, 2)
df
}
esttab(fit1, fit2, digits = 1)
