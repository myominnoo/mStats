source("./R/mStats.R")
recode <- function(data, var, ... )
{
## match call arguments
.args <- as.list(match.call())
var <- .args$var
.var <- data[[var]]
.lbl <- attr(.var, "label")
## change double to numeric
if (is.double(.var)) {
.var <- as.numeric(.var)
} else if (is.factor(.var)) {
.var <- as.character(.var)
}
vals <- .args[-c(1:3)]
lapply(vals, function(z) {
.val <- as.character(z)
.old <- ifelse(.val[2] == "NA", NA, .val[2])
.new <- ifelse(.val[3] == "NA", NA,
ifelse(.val[3] == "NULL", NULL, .val[3]))
.chk <- .var == .old
if (grepl(":", .old)) {
.old <- eval(parse(text = .old))
.chk <- .var >= .old[1] & .var <= .old[length(.old)]
} else if (is.na(.old)) {
.chk <- is.na(.var)
}
if (any(.chk)) {
if (any(is.na(.old))) {
.var[is.na(.var)] <<- .new
} else {
.var[.chk] <<- .new
}
} else {
stop(paste0("`", .old, "` not found in '", var, "'"),
call. = FALSE)
}
## Print notification message
cat(paste0("  ( ", length(which(.chk)), " values recoded as '",
.new, "')\n"))
})
if (is.factor(data[[var]])) .var <- factor(.var)
attr(.var, "label") <- .lbl
data[[var]] <- .var
return(data)
}
codebook(infert)
tab(infert, case)
recode(infert, case, 0/1, 1/0) %>%
tab(case)
recode(infert, case, 0/1, 1/0)
