pwid %>%
    drop(hbsvacEn, hbsvacCom) %>%
    keep(age, sex, regdate, marital:route, hivres, oc, ocdate) %>%
    rename(c(drugtype, agefstdrg, typfstdrg, durdrguse, hivres),
           c(drugType, ageFirstDrugUse, typeFirstDrugUse, durDrugUse, hivRes)) %>%
    filter(age > 30, age < 45) %>%
