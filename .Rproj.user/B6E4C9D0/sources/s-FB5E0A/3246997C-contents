## Milestone Project: Code Demonstration


we will re-create Table 1 from the dataset.    

As you can see in the codebook, almost 40% of VLRcat and AdherenceR have missing values.    

Meta-data for the dataset can be found [here](https://doi.org/10.1371/journal.pone.0214014). 



```{r preparation, include=TRUE}
## loading the mStats and magrittr
library(mStats)
library(magrittr)
## clear the workspace
clear()

## logging the console outputs
ilog("./data/mStats_Demo.txt", append = FALSE)

## reading xls format using readxl 
hiv <- readxl::read_excel("./data/pone.0214014.s001.xls")
## checking data structure 
str(hiv)
## codebook 
codebook(hiv)


## Table 1: variables needed 
## Sex, TB, District, WHOstage, ARVregimen, ARVStart, ARVtablet
## Nutrition, CD4, Relation, RelativeHIV, SiblingsHIV, Literacy
hiv.tables <- hiv %>% 
    
    # remove the rest of variables
    lose(DiagnHIV, CTX, Vitamin, IPT, Infection, Adherence, AdherenceR) %>%
    
    # recoding values 
    recode(Sex, c("F", "M"), c("Female", "Male")) %>% 
    recode(TB, c("y", "n"), c("Positive", "Negative")) %>% 
    recode(District, c(1, 2), c("Misungwi", "others")) %>%
    recode(WHOstage, c(1,2,3,4), c("I", "II", "III", "IV")) %>%
    
    # generate ARV for abbreviations
    generate(ARV, ARVregimen) %>% 
    # recoding ARV 
    recode(ARV, 
           c(1, 2, 3, 
             4, 5, 6, 7), 
           c("3TC+AZT+NVP", "3TC+AZT+EFV", "ABC+3CT+EFV", 
             "ABC+3TC+LPV/r", "ABC+3TC+LPV/r", "TDF+FDC+ATV/r", 
             "ABC+3TC+ATV/r")) %>%
    
    # new variable for classifying PI and Non-PI based regimens
    generate(ARVpi, ifelse(ARVregimen < 4, "Non-PI", "PI")) %>% 
    
    # new variable to calculate time on ART: date difference / 365.25 = years
    generate(timeART, as.numeric(as.Date("2017-12-31") - as.Date(ARVStart)) / 365.25) %>% 
    # egen timeART.grp 
    egen(timeART, c(2.0, 6.0, 9.0), c("3-24M", "25M-5Yr", "6-8Yr", "9+Yr"), 
         timeART.grp) %>%
    
    # number of ARV tablets
egen(ARVtablet, c(2.5, 4.5, 6),
     c("<=2.4", "2.5-4.4", "4.5-5.9", "6+"), ARVtab.grp) %>%

    # recode nutrition: 1 = normal, 2 = moderate, 3 = severe malnourished
    recode(Nutrition, c(1,2,3), c("Normal", "Moderate", "Severe")) %>%

    # egen CD4 group: cut-off point 351
    egen(CD4, c(0, 351), c("<=350", "351+"), cd4.grp) %>%
    # egen CD4 group: cut-point 500
    egen(CD4, c(0, 501), c("<=500", "501+"), cd4.grp2) %>%
    
    # recode relation: 1 = Mother, 2 = Father, 3 = Relative, 4 = Other
    recode(Relation, c(1,2,3,4), c("Mother", "Father", "Relative", "Others")) %>%
    # recode HIV Caregiver
    recode(RelativeHIV, c("y", "n"), c("Yes", "No")) %>%
    # recode siblings HIV
    recode(SiblingsHIV, c("y", "n"), c("Yes", "No")) %>%
    # recode caregiver literacy
    recode(Literacy, c("y", "n"), c("Yes", "No")) %>%
    
    # new variable for viral suppression: vlSuppress 
    generate(vlSuppress, ifelse(VLcat < 2, 1, 0)) %>% 
    
    # keep all we want for Table 1 and 2
    keep(Sex, TB, District, WHOstage, ARVpi, ARV, timeART.grp, ARVtab.grp,
         Nutrition, cd4.grp, Relation, RelativeHIV, SiblingsHIV, Literacy, 
         timeART, Nregimens, cd4.grp2, vlSuppress) %>%
    
    # variable labels
    labelVars(c(Sex, TB,
                District, WHOstage,
                ARVpi, ARV, timeART.grp,
                ARVtab.grp, Nutrition,
                cd4.grp, Relation, RelativeHIV,
                SiblingsHIV, Literacy, 
                timeART, Nregimens, cd4.grp2, vlSuppress),
              c("Gender", "History of TB", 
                "District: 1=Misungwi,2=others", "WHO Clinical Staging",
                "ART PI-NonPI", "ARV regimens", "Time on ART Category",
                "number of ARV tablet/day", "Nutritional Status",
                "CD4 group: 350", "Relation with Caregiver", "HIV+ Caregiver",
                "HIV+ Siblings", "Literacy of caregiver", 
                "Time on ART Years", "Previous Regimens", 
                "CD4 group: 500", "Viral Suppression"))

# check codebook 
codebook(hiv.tables)

## Table 1: tabulation 
tab(hiv.tables)

## Summary measures (not included in Table 1)
summ(hiv.tables)

## Table 2: cross-tabulation by Viral Suppression 
xtab(hiv.tables, vlSuppress)

## Summary measures Grouped by Viral Suppression 
summBy(hiv.tables, vlSuppress)

## Logistic Regression: Sex
logit.sex <- glm(vlSuppress ~ Sex, data = hiv.tables, family = binomial)
fModelOutput(logit.sex)
testModelFit(logit.sex)

## Logistic Regression: District
logit.district <- glm(vlSuppress ~ District, data = hiv.tables, 
                      family = binomial)
fModelOutput(logit.district)
testModelFit(logit.district)

## Logistic Regression: CD4
logit.cd4 <- glm(vlSuppress ~ cd4.grp2, data = hiv.tables, 
                 family = binomial)
fModelOutput(logit.cd4)
testModelFit(logit.cd4)

## Logistic Regression: Previous Regimens
logit.Nregimens <- glm(vlSuppress ~ Nregimens, data = hiv.tables, 
                 family = binomial)
fModelOutput(logit.Nregimens)
testModelFit(logit.Nregimens)

## Logistic Regression: Time on ART
logit.timeART <- glm(vlSuppress ~ timeART, data = hiv.tables, 
                 family = binomial)
fModelOutput(logit.timeART)
testModelFit(logit.timeART)


## Multivariable logistic Regression Model 
logit.multi <- glm(vlSuppress ~ Sex + District + cd4.grp2, 
                   data = hiv.tables, family = binomial)
fModelOutput(logit.multi)
testModelFit(logit.multi)


## Close the log file
ilog.close()
```





